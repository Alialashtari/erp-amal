# Amal ERP Core - environment template. Copy to .env and fill values.
# All secrets come from the environment; never commit real values. (Constitution Art. 6.1)

NODE_ENV=development
PORT=3000

# PostgreSQL (Constitution Art. 2)
DATABASE_URL=postgresql://amal:amal_dev_password@localhost:5432/amal_erp?schema=public

# JWT (ADR-009)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_TTL_DAYS=30

# Redis (ADR-008) - wired in Phase 2 (queues/cache); provisioned now
REDIS_URL=redis://localhost:6379

# MinIO / S3 (ADR-009) - wired in Phase 2 (storage module); provisioned now
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=amal
S3_SECRET_KEY=amal_dev_password
S3_BUCKET=amal-erp

# Bootstrap super admin (created by prisma seed if no users exist)
SEED_ADMIN_EMAIL=admin@amal.local
SEED_ADMIN_PASSWORD=ChangeMe!12345

# Rate limiting
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100

# CORS (production: REQUIRED, comma-separated explicit origins; no wildcard)
# CORS_ORIGINS=https://admin.amal.org,https://amal.org
CORS_ORIGINS=

# Swagger UI in production (default off; docs always generated in dev)
SWAGGER_ENABLED=false

# Receipts (ADR-020): Arabic-capable TTF for PDFKit
# RECEIPT_FONT_PATH=/app/assets/fonts/NotoNaskhArabic-Regular.ttf
