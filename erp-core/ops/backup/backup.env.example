# Amal ERP backup configuration. Copy to backup.env (git-ignored) and fill in.
# Targets fixed by ADR-024: RPO = 1 hour, RTO = 6 hours.
# RPO 1h requires HOURLY WAL ARCHIVING in addition to these dumps:
#   configure archive_command/pgBackRest on the postgres container shipping
#   WAL to $OFFSITE_TARGET (see 08_OPERATIONS/02_Backup_and_DR_Architecture.md §3).

# Postgres connection (matches docker-compose.prod.yml .env)
POSTGRES_USER=amal
POSTGRES_DB=amal_erp

# Where dumps are written on the VPS
# BACKUP_ROOT=/var/backups/amal-erp

# Retention counts (confirmed by ADR-024)
KEEP_DAILY=14
KEEP_WEEKLY=8
KEEP_MONTHLY=12

# Off-site copy: rclone remote ("remote:bucket/path") or SSH path ("user@host:/path")
# REQUIRED for production (Art. 9.2 / ADR-024). Record the choice in the ops journal.
OFFSITE_TARGET=

# Object storage bucket
S3_BUCKET=amal-erp
